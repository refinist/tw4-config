{
  "name": "@refinist/tw4-config",
  "version": "1.0.0",
  "description": "Tailwind CSS v4 utility preset for mobile and modern web development.",
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwindcss-v4",
    "weapp-tailwindcss",
    "weapp",
    "css",
    "config",
    "mobile",
    "safe-area",
    "flex"
  ],
  "homepage": "https://github.com/refinist/tw4-config#readme",
  "bugs": {
    "url": "https://github.com/refinist/tw4-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/refinist/tw4-config.git"
  },
  "license": "MIT",
  "author": "REFINIST",
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.css",
    "./index.css": "./dist/index.css",
    "./index": "./dist/index.css",
    "./weapp-tailwindcss.css": "./dist/weapp-tailwindcss.css",
    "./weapp-tailwindcss": "./dist/weapp-tailwindcss.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.css src/weapp-tailwindcss.css --outdir=dist --minify",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp && pnpm publish"
  },
  "prettier": "@refinist/prettier-config",
  "devDependencies": {
    "@refinist/prettier-config": "^1.2.0",
    "bumpp": "^10.2.0",
    "esbuild": "^0.25.8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.11",
    "weapp-tailwindcss": "^4.12.0"
  },
  "peerDependenciesMeta": {
    "weapp-tailwindcss": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.17.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
